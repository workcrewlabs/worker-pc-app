# Shared local development
NODE_ENV=development
WORKCREW_API_URL=http://127.0.0.1:8787

# Auth and billing providers. "local" and "simulated" need no external
# accounts and run the real sign in and hard paywall locally. Switch to
# "supabase" and "stripe" once those credentials are configured below.
AUTH_MODE=local
BILLING_MODE=simulated
# Required when AUTH_MODE is local. A 64 character random hex string keeps
# issued sessions valid across restarts. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKCREW_LOCAL_AUTH_SECRET=

# Developer bypasses. Keep these false so the real sign in and paywall appear.
WORKCREW_DEV_AUTH=false
WORKCREW_DEV_BILLING=false
# Mock AI returns canned responses for offline testing. Set to false once an
# Anthropic API key is configured to use the real Claude API.
WORKCREW_MOCK_AI=true

# Database. Local development uses a SQLite file. Production uses Supabase
# Postgres: set DATABASE_URL to the Supabase Postgres connection URI (it
# contains the database password). Backend only, never in the desktop app.
WORKCREW_DATA_URL=file:workcrew.db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Supabase. The URL and anon key are public (used by the desktop and backend).
# The service role key is secret and lives only in the backend.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Production billing. The secret key and webhook secret are backend only. The
# publishable key is public. The four price ids come from your Stripe products.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_ULTRA_MONTHLY_PRICE_ID=price_xxx
STRIPE_ULTRA_YEARLY_PRICE_ID=price_xxx
WORKCREW_BILLING_SUCCESS_URL=workcrew://billing/success
WORKCREW_BILLING_CANCEL_URL=workcrew://billing/cancel

# Production model service
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_OPUS_MODEL=claude-opus-4-8

# Security
WORKCREW_ALLOWED_ORIGINS=http://127.0.0.1:5173
WORKCREW_LOG_LEVEL=info

# Optional remote libSQL database
WORKCREW_DATA_AUTH_TOKEN=

# Optional packaged Windows helper path
WORKCREW_WINDOWS_AGENT=
