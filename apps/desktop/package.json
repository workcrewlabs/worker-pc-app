{
  "name": "@workcrew/desktop",
  "version": "0.1.21",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "npm run build -w @workcrew/contracts",
    "dev": "cross-env DOTENV_CONFIG_PATH=../../.env electron-vite dev",
    "prebuild": "npm run build -w @workcrew/contracts",
    "build": "electron-vite build",
    "build:helper": "cd ../../python/windows-agent && py -m PyInstaller --noconfirm workcrew-windows-agent.spec",
    "package": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@workcrew/contracts": "0.1.0",
    "dotenv": "latest",
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1",
    "pdfjs-dist": "3.11.174",
    "playwright-core": "^1.61.0",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "typescript": "latest",
    "vite": "7.3.5",
    "vitest": "latest"
  },
  "build": {
    "appId": "com.workcrew.desktop",
    "productName": "WorkCrew",
    "asar": true,
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/playwright-core/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/pdfjs-dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../../python/windows-agent/dist/workcrew-windows-agent.exe",
        "to": "windows-agent/workcrew-windows-agent.exe"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "workcrewlabs",
        "repo": "worker-pc-app",
        "releaseType": "release"
      }
    ],
    "protocols": [
      {
        "name": "WorkCrew",
        "schemes": [
          "workcrew"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "artifactName": "WorkCrew-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
